{
	"name": "@nan0web/ui-react",
	"version": "1.1.2",
	"description": "React UI components for nan0web with SSG and SSR support",
	"main": "./src/index.jsx",
	"types": "./types/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./types/index.d.ts",
			"default": "./src/index.jsx"
		},
		"./components/atoms/*": {
			"types": "./types/components/atoms/*.d.ts",
			"default": "./src/components/atoms/*.jsx"
		},
		"./components/molecules/*": {
			"types": "./types/components/molecules/*.d.ts",
			"default": "./src/components/molecules/*.jsx"
		},
		"./components/organisms/*": {
			"types": "./types/components/organisms/*.d.ts",
			"default": "./src/components/organisms/*.jsx"
		},
		"./context": {
			"types": "./types/context/*.d.ts",
			"default": "./src/context/*.jsx"
		},
		"./vite": {
			"types": "./types/vite/index.d.ts",
			"default": "./src/vite/index.js"
		}
	},
	"scripts": {
		"build": "(tsc -p tsconfig.json || true) && vite build",
		"dev": "vite",
		"play": "echo 'Open browser http://localhost:4246/play/\\n' && vite --port 4246",
		"preview": "vite preview",
		"test": "npm run test:js && npm run test:jsx",
		"test:js": "node --test  --test-timeout=6333 --test-reporter=tap \"src/**/*.test.js\"",
		"test:docs": "vitest run src/README.md.jsx",
		"test:jsx": "vitest run --reporter tap",
		"test:debug": "vitest --inspect --no-file-parallelism",
		"test:status": "nan0test status --hide-name --debug",
		"test:all": "npm run test && npm run build && npm run knip",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"knip": "knip --production",
		"precommit": "npm test",
		"prepush": "npm test",
		"prepare": "husky",
		"release": "nan0release publish",
		"clean": "rm -rf .cache/ && rm -rf dist/",
		"clean:modules": "rm -rf node_modules"
	},
	"keywords": [
		"react",
		"ui",
		"ssg",
		"ssr",
		"nan0web"
	],
	"author": "YaRaSLove (ЯRаСлав) <support@yaro.page>",
	"license": "ISC",
	"packageManager": "pnpm@10.11.0",
	"devDependencies": {
		"@nan0web/auth-core": "^1.0.0",
		"@nan0web/core": "^1.0.3",
		"@nan0web/db": "^1.2.2",
		"@nan0web/db-browser": "workspace:*",
		"@nan0web/ui": "^1.2.0",
		"@nan0web/ui-core": "^1.0.0",
		"@playwright/test": "^1.58.1",
		"@testing-library/jest-dom": "^6.8.0",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@vitejs/plugin-react": "^5.0.3",
		"@vitest/ui": "3.2.4",
		"bootstrap": "^5.3.3",
		"happy-dom": "^20.4.0",
		"js-yaml": "^4.1.0",
		"knip": "^5.82.1",
		"prop-types": "^15.8.1",
		"react-icons": "^5.4.0",
		"vite": "^7.3.1",
		"vitest": "^3.2.4"
	},
	"peerDependencies": {
		"@nan0web/auth-core": "^1.0.0",
		"@nan0web/core": "^1.0.3",
		"@nan0web/db": "^1.2.2",
		"@nan0web/db-browser": "workspace:*",
		"@nan0web/i18n": "^1.0.1",
		"@nan0web/ui": "^1.2.0",
		"@nan0web/ui-core": "^1.0.0",
		"prop-types": "^15.8.1",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"dependencies": {
		"@nan0web/log": "^1.1.1",
		"marked": "^17.0.3"
	}
}
